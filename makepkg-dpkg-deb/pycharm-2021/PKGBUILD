pkgname=pycharm-2021
pkgver=2021.2.2
pkgrel=1
arch=(any)

pkgdesc="The only Python IDE you need"

source=(
	control
	https://download.jetbrains.com/python/pycharm-professional-$pkgver.tar.gz
)
sha256sums=(
	e1c8802e60589fd47c32b43794b787f6c860cb8d55babe5a1f75678670671fbd
	a6dc59213bdd728b628f14179e3da271eea2344cced8ee50be71582392abf555
)

package() {
	mkdir -m 755 -p "$pkgdir/usr/share"
	cp -a "$srcdir/pycharm-"*'/' "$pkgdir/usr/share/$pkgname/"

	mkdir -m 755 -p "$pkgdir/usr/bin"
	ln -s ../share/$pkgname/bin/pycharm.sh "$pkgdir/usr/bin/$pkgname"

	mkdir -m 755 -p "$pkgdir/usr/share/applications"

	unzip -qou "$srcdir/pycharm-"*"/lib/platform-impl.jar" entry.desktop
	sed -i 's/\$NAME\$/PyCharm 2021/' entry.desktop
	sed -i "s/\\\$ICON\\\$/$pkgname/" entry.desktop
	sed -i "s/\\\$SCRIPT\\\$/$pkgname/" entry.desktop
	sed -i "s/\\\$COMMENT\\\$/$pkgdesc/" entry.desktop
	sed -i "s/\\\$WM_CLASS\\\$/$pkgname/" entry.desktop
	install -D -m644 "$srcdir/entry.desktop" "$pkgdir/usr/share/applications/$pkgname.desktop"

	mkdir -m 755 -p "$pkgdir/usr/share/pixmaps"
	install -D -m644 "$srcdir/pycharm-"*"/bin/pycharm.svg" "$pkgdir/usr/share/pixmaps/$pkgname.svg"

	makedeb
}

source ../func
